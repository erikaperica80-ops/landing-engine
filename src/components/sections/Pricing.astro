---
interface PricingPlan {
  plan: string;
  price: string;
  features: string[];
}

interface Props {
  plans: PricingPlan[];
  dark?: boolean;
}

const { plans, dark = false } = Astro.props;
---

<section class:list={['py-20 px-6', dark ? 'bg-gray-900 text-white' : 'bg-white text-gray-900']}>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Pricing</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {plans.map((plan, i) => (
        <div class:list={['rounded-2xl p-8 shadow-md flex flex-col gap-4', i === 1 ? 'bg-blue-600 text-white ring-2 ring-blue-400' : dark ? 'bg-gray-800' : 'bg-gray-50']}>
          <h3 class="text-xl font-bold">{plan.plan}</h3>
          <p class="text-4xl font-extrabold">{plan.price}</p>
          <ul class="space-y-2 flex-1">
            {plan.features.map((f) => (
              <li class="flex items-center gap-2">
                <span>✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
          <button class:list={['mt-4 py-2 px-4 rounded-lg font-semibold transition', i === 1 ? 'bg-white text-blue-600 hover:bg-gray-100' : 'bg-blue-600 text-white hover:bg-blue-700']}>
            Get Started
          </button>
        </div>
      ))}
    </div>
  </div>
</section>
