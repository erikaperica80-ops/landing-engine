---
interface Props {
  title?: string;
  items: string[];
  dark?: boolean;
}

const { title = 'Features', items, dark = false } = Astro.props;
---

<section class:list={['py-20 px-6', dark ? 'bg-gray-800 text-white' : 'bg-gray-50 text-gray-900']}>
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">{title}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {items.map((feature) => (
        <div class:list={['rounded-xl p-6 shadow-sm', dark ? 'bg-gray-700' : 'bg-white']}>
          <div class="text-blue-500 text-3xl mb-3">✓</div>
          <p class="font-medium text-lg">{feature}</p>
        </div>
      ))}
    </div>
  </div>
</section>
