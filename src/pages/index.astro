---
import Layout from '../layouts/Layout.astro';
import SaasTemplate from '../templates/SaasTemplate.astro';
import BusinessTemplate from '../templates/BusinessTemplate.astro';
import RestaurantTemplate from '../templates/RestaurantTemplate.astro';
import GymTemplate from '../templates/GymTemplate.astro';
import PortfolioTemplate from '../templates/PortfolioTemplate.astro';

const { tenantId, tenantConfig } = Astro.locals;
---

<Layout tenantConfig={tenantConfig}>
  {!tenantId && (
    <div class="flex flex-col items-center justify-center min-h-screen p-8 text-center">
      <h1 class="text-3xl font-bold mb-4">No tenant specified</h1>
      <p class="text-gray-600 mb-6">Add <code class="bg-gray-100 px-2 py-1 rounded">?tenant=your-tenant-id</code> to the URL to load a tenant landing page.</p>
    </div>
  )}

  {tenantId && !tenantConfig && (
    <div class="flex flex-col items-center justify-center min-h-screen p-8 text-center">
      <h1 class="text-3xl font-bold mb-4">Tenant not found</h1>
      <p class="text-gray-600 mb-6">We couldn't load the configuration for <strong>{tenantId}</strong>. Please check the tenant ID or try again later.</p>
      <a href="/" class="text-blue-600 underline">← Back to home</a>
    </div>
  )}

  {tenantConfig?.template === 'saas' && <SaasTemplate config={tenantConfig} />}
  {tenantConfig?.template === 'business' && <BusinessTemplate config={tenantConfig} />}
  {tenantConfig?.template === 'restaurant' && <RestaurantTemplate config={tenantConfig} />}
  {tenantConfig?.template === 'gym' && <GymTemplate config={tenantConfig} />}
  {tenantConfig?.template === 'portfolio' && <PortfolioTemplate config={tenantConfig} />}

  {tenantConfig && !['saas', 'business', 'restaurant', 'gym', 'portfolio'].includes(tenantConfig.template) && (
    <div class="flex flex-col items-center justify-center min-h-screen p-8 text-center">
      <h1 class="text-3xl font-bold mb-4">Unknown template</h1>
      <p class="text-gray-600">Template "<strong>{tenantConfig.template}</strong>" is not supported.</p>
    </div>
  )}
</Layout>
